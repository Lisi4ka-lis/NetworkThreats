@page "/"
@inject IThreatService ThreatService
@inject ICategoryService CategoryService
@inject IMitigationService MitigationService
@inject NavigationManager Nav

<PageTitle>Главная — NetworkThreats</PageTitle>

<div class="mb-4">
    <h2 class="mb-1">Система классификации сетевых угроз</h2>
    <p class="text-muted">Справочник сетевых угроз, методов атак и способов защиты</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="cursor:pointer" @onclick='() => Nav.NavigateTo("/threats")'>
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                    <i class="bi bi-shield-exclamation fs-3 text-danger"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@threatCount</div>
                    <div class="text-muted">Угроз в базе</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="cursor:pointer" @onclick='() => Nav.NavigateTo("/categories")'>
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-tags-fill fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@categoryCount</div>
                    <div class="text-muted">Категорий</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="cursor:pointer" @onclick='() => Nav.NavigateTo("/mitigations")'>
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-shield-check fs-3 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@mitigationCount</div>
                    <div class="text-muted">Методов защиты</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Критические угрозы
            </div>
            <div class="card-body p-0">
                @if (criticalThreats is null)
                {
                    <p class="p-3 text-muted">Загрузка...</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var t in criticalThreats)
                        {
                            var threatId = t.Id;
                            <li class="list-group-item list-group-item-action"
                                style="cursor:pointer"
                                @onclick='() => Nav.NavigateTo("/threats/" + threatId)'>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>@t.Name</span>
                                    <span class="badge bg-danger">Критический</span>
                                </div>
                                <small class="text-muted">@t.CategoryName</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">
                <i class="bi bi-shield-fill-check text-success me-2"></i>Превентивные методы защиты
            </div>
            <div class="card-body p-0">
                @if (preventiveMethods is null)
                {
                    <p class="p-3 text-muted">Загрузка...</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var m in preventiveMethods)
                        {
                            <li class="list-group-item">
                                <div class="fw-semibold">@m.Name</div>
                                <small class="text-muted">@m.ShortDescription</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private int threatCount;
    private int categoryCount;
    private int mitigationCount;
    private IEnumerable<ThreatDto>? criticalThreats;
    private IEnumerable<MitigationMethodDto>? preventiveMethods;

    protected override async Task OnInitializedAsync()
    {
        var threats = await ThreatService.GetAllAsync();
        var categories = await CategoryService.GetAllAsync();
        var mitigations = await MitigationService.GetAllAsync();

        threatCount = threats.Count();
        categoryCount = categories.Count();
        mitigationCount = mitigations.Count();

        criticalThreats = threats.Where(t => t.Severity == "critical");
        preventiveMethods = mitigations.Where(m => m.Type == "preventive");
    }
}
