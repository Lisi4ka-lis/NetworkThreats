@page "/categories"
@inject ICategoryService CategoryService
@inject NavigationManager Nav

<PageTitle>Категории угроз</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Категории угроз</h3>
    <button class="btn btn-primary" @onclick="OpenAddModal">
        <i class="bi bi-plus-circle me-1"></i>Добавить категорию
    </button>
</div>

@if (categories is null)
{
    <p>Загрузка...</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var cat in categories)
        {
            <div class="col">
                <div class="card h-100 category-card"
                     style="cursor:pointer"
                     @onclick='() => Nav.NavigateTo("/threats?categoryId=" + cat.Id)'>
                    <div class="card-body">
                        <h5 class="card-title">@cat.Name</h5>
                        <p class="card-text text-muted">@(cat.Description ?? "—")</p>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <span class="badge bg-primary">@cat.ThreatsCount угроз</span>
                        <span class="text-muted small">
                            Смотреть угрозы <i class="bi bi-arrow-right ms-1"></i>
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ── Модальное окно добавления категории ── *@
@if (showAddModal)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-folder-plus me-2"></i>Новая категория
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <EditForm Model="newCategory" OnValidSubmit="SaveCategory">
                    <FluentValidationValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Название *</label>
                            <InputText class="form-control" @bind-Value="newCategory.Name"
                                       placeholder="Например: Сетевые атаки" />
                            <ValidationMessage For="@(() => newCategory.Name)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Описание</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="newCategory.Description"
                                          placeholder="Краткое описание категории" />
                            <ValidationMessage For="@(() => newCategory.Description)" class="text-danger small" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary"
                                @onclick="CloseAddModal">Отмена</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Создать
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private IEnumerable<ThreatCategoryDto>? categories;

    private bool showAddModal;
    private ThreatCategory newCategory = new();

    protected override async Task OnInitializedAsync() =>
        categories = await CategoryService.GetAllAsync();

    private void OpenAddModal()
    {
        newCategory = new ThreatCategory();
        showAddModal = true;
    }

    private void CloseAddModal()
    {
        showAddModal = false;
    }

    private async Task SaveCategory()
    {
        await CategoryService.CreateAsync(newCategory);
        CloseAddModal();
        categories = await CategoryService.GetAllAsync();
    }
}
