@inherits LayoutComponentBase
@namespace NetworkThreats.Shared

<div class="app-layout">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <div class="main-wrapper">
        <header class="top-bar">
            <div class="top-bar-inner">
                <div class="top-bar-title">
                    <i class="bi bi-cpu me-2 text-accent"></i>Система мониторинга сетевых угроз
                </div>
                <div class="top-bar-badge">
                    <i class="bi bi-circle-fill text-success me-1" style="font-size:0.5rem;vertical-align:middle;"></i>
                    <span>Активна</span>
                </div>
            </div>
        </header>

        <main class="page-content">
            @Body
        </main>

        <footer class="page-footer">
            <span>NetworkThreats &copy; @DateTime.Now.Year</span>
        </footer>
    </div>
</div>
